# Locked PyTorch CPU wheels for Docker INSTALL_EXTRAS=torch (not pip-audit in CI: Linux
# torch 2.12 pulls cuda-toolkit transitives that are platform-specific and unhashable).
# Regenerate: python scripts/compile_locked_requirements.py
# torch 2.12 requires setuptools<82; pin explicitly for --require-hashes installs.
--extra-index-url https://download.pytorch.org/whl/cpu
setuptools<82
torch==2.12.0+cpu
