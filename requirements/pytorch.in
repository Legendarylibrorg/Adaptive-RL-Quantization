# Locked PyTorch CPU wheels for pip-audit, scheduled audit, and Docker INSTALL_EXTRAS=torch.
# Regenerate: python scripts/compile_locked_requirements.py
# torch 2.12 requires setuptools<82; pin explicitly for --require-hashes installs.
--extra-index-url https://download.pytorch.org/whl/cpu
setuptools<82
torch==2.12.0
